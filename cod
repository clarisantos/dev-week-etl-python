
import pandas as pd
import csv

# --- ETAPA 0: CRIAR CSV BASE ---
dados = [
    ["Nome", "Saldo"],
    ["Clara", 500],
    ["Junior", 2500],
    ["Ana", -100]
]

with open("usuarios.csv", "w", newline="", encoding="utf-8") as arquivo:
    writer = csv.writer(arquivo)
    writer.writerows(dados)

print("Arquivo usuarios.csv criado!")

# --- ETAPA 1: EXTRAÇÃO (Extract) ---
def extract(caminho_arquivo):
    print(f"Lendo dados de: {caminho_arquivo}...")
    return pd.read_csv(caminho_arquivo)

# --- ETAPA 2: TRANSFORMAÇÃO (Transform) ---
def transform(df):
    print("Iniciando transformação dos dados...")
    
    mensagens = []

    for index, row in df.iterrows():

        if row['Saldo'] < 0:
            msg = f"Olá {row['Nome']}, notamos um saldo negativo. Confira nossas opções de crédito com juros baixos!"

        elif row['Saldo'] < 1000:
            msg = f"Olá {row['Nome']}, que tal começar uma reserva de emergência? Temos planos a partir de R$ 50,00."

        else:
            msg = f"Olá {row['Nome']}, seu saldo está excelente! Conheça nossas opções de investimento."

        mensagens.append(msg)

    df['Mensagem_Marketing'] = mensagens

    return df

# --- ETAPA 3: CARREGAMENTO (Load) ---
def load(df, output_path):
    df.to_csv(output_path, index=False, encoding="utf-8")
    print(f"Sucesso! Arquivo final gerado em: {output_path}")

# --- EXECUÇÃO DO PIPELINE ---
if __name__ == "__main__":

    try:
        # EXTRAÇÃO
        df_base = extract('usuarios.csv')

        # TRANSFORMAÇÃO
        df_com_mensagens = transform(df_base)

        # CARREGAMENTO
        load(df_com_mensagens, 'desafio_final_sdw.csv')

    except FileNotFoundError:
        print("Erro: O arquivo 'usuarios.csv' não foi encontrado.")
